# FinBot Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys (choose one based on llm_provider)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# LLM Configuration
LLM_PROVIDER=anthropic  # Options: anthropic, openai, ollama
LLM_MODEL=claude-3-5-sonnet-20241022  # or gpt-4, llama2, etc
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# Ollama (if using local models)
OLLAMA_BASE_URL=http://localhost:11434

# Paths (defaults should work, but can override)
# MODEL_PATH=models/lead_scorer.pkl
# DATA_PATH=data/
# LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Training Configuration
TEST_SIZE=0.2
RANDOM_STATE=42
OPTUNA_N_TRIALS=50

# Agent Configuration
LEAD_SCORE_THRESHOLD=0.7
CONVERSATION_MAX_HISTORY=10
